spring.application.name=thesis_backend
spring.datasource.url=jdbc:mysql://localhost:3306/thesis_db?createDatabaseIfNotExist=true
spring.datasource.username=your_database_username_here
spring.datasource.password=your_database_password_here
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
server.port=8080